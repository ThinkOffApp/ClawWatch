<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- SPLASH: shown on startup while initialising -->
    <LinearLayout
        android:id="@+id/splashPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="ClawWatch"
            android:scaleType="fitCenter" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ClawWatch"
            android:textColor="#D4A5E9"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp" />

        <ProgressBar
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

    <!-- SETUP PANEL: shown when no API key -->
    <LinearLayout
        android:id="@+id/setupPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Run set_key.sh\nfrom your Mac"
            android:textColor="#D4A5E9"
            android:textSize="12sp"
            android:gravity="center" />

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="11sp"
            android:inputType="textPassword"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveKeyBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="8dp"
            android:backgroundTint="#D4A5E9"
            android:visibility="gone" />

    </LinearLayout>

    <!-- MAIN PANEL: shown after setup -->
    <LinearLayout
        android:id="@+id/mainPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Starting…"
            android:textColor="#D4A5E9"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/live_text_bg"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="124dp"
            android:layout_height="124dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/avatarFace"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🐜"
                android:textColor="#D4A5E9"
                android:textSize="72sp" />

            <TextView
                android:id="@+id/actionIndicator"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="end|top"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:text="◎"
                android:textColor="#D4A5E9"
                android:textSize="24sp"
                android:includeFontPadding="false" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/autoListenCountdown"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:max="100"
                android:visibility="gone"
                app:indicatorColor="#D4A5E9"
                app:indicatorSize="60dp"
                app:trackColor="#00000000"
                app:trackThickness="3dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/fab"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="center"
                android:contentDescription="Tap to talk"
                android:background="@drawable/action_bubble_bg"
                android:elevation="0dp"
                android:gravity="center"
                android:includeFontPadding="false"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:padding="0dp"
                android:stateListAnimator="@null"
                android:text="◉"
                android:textAllCaps="false"
                android:textColor="#0A0A0F"
                android:textSize="18sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Legacy bound views kept hidden for compatibility -->
        <TextView
            android:id="@+id/queryText"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:visibility="invisible" />

        <TextView
            android:id="@+id/responseText"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text=""
            android:visibility="invisible" />

        <ProgressBar
            android:id="@+id/thinkingIndicator"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.wear.widget.BoxInsetLayout>
