<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- SETUP PANEL: shown when no API key -->
    <LinearLayout
        android:id="@+id/setupPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Anthropic API Key"
            android:textColor="#D4A5E9"
            android:textSize="13sp"
            android:gravity="center" />

        <EditText
            android:id="@+id/apiKeyInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="sk-ant-..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:textSize="11sp"
            android:inputType="textPassword"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/saveKeyBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="8dp"
            android:backgroundTint="#D4A5E9" />

    </LinearLayout>

    <!-- MAIN PANEL: shown after setup -->
    <LinearLayout
        android:id="@+id/mainPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Starting…"
            android:textColor="#888888"
            android:textSize="11sp"
            android:gravity="center"
            android:maxLines="1" />

        <TextView
            android:id="@+id/queryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:gravity="center"
            android:maxLines="2"
            android:layout_marginTop="4dp" />

        <ProgressBar
            android:id="@+id/thinkingIndicator"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/responseText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text=""
            android:textColor="#D4A5E9"
            android:textSize="12sp"
            android:gravity="center"
            android:maxLines="5"
            android:layout_marginTop="4dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:contentDescription="Tap to talk"
            app:srcCompat="@android:drawable/ic_btn_speak_now"
            app:backgroundTint="#D4A5E9"
            app:fabSize="mini" />

    </LinearLayout>

</androidx.wear.widget.BoxInsetLayout>
